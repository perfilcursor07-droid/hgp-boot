<%
    const isSidebarAdmin = typeof isAdmin === 'boolean' ? isAdmin : true;
    const sidebarRole = typeof role !== 'undefined' ? role : 'Administrador';
    const userInitial = typeof username === 'string' && username.length ? username.charAt(0).toUpperCase() : 'U';
    const menuItems = [
        { key: 'dashboard', href: '/dashboard', label: 'Dashboard', caption: 'Visão geral do painel', icon: '📊', visible: isSidebarAdmin },
        { key: 'chamados', href: '/chamados', label: 'Chamados', caption: 'Fila e atendimento ativo', icon: '🧾', visible: true },
        { key: 'messages', href: '/messages', label: 'Mensagens', caption: 'Histórico de conversas', icon: '💬', visible: isSidebarAdmin },
        { key: 'contacts', href: '/contacts', label: 'Contatos', caption: 'Base sincronizada', icon: '👥', visible: isSidebarAdmin },
        { key: 'usuarios', href: '/usuarios', label: 'Usuários', caption: 'Permissões e acessos', icon: '👤', visible: isSidebarAdmin },
        { key: 'settings', href: '/settings', label: 'Configurações', caption: 'Arquivos e parâmetros', icon: '⚙️', visible: isSidebarAdmin }
    ];
%>

<aside class="sidebar">
    <div class="sidebar-shell">
        <div class="sidebar-header">
            <div class="sidebar-brand">
                <div class="sidebar-brand-mark">WA</div>
                <div class="sidebar-brand-copy">
                    <span class="sidebar-kicker">Node Control</span>
                    <h1>WhatsApp HGP</h1>
                </div>
            </div>
            <p class="sidebar-subtitle">Atendimento, monitoramento e configuração em um painel central com visual mais limpo.</p>
        </div>

        <div class="sidebar-section-label">Navegação</div>

        <nav class="sidebar-menu">
            <% menuItems.forEach((item) => { %>
                <% if (item.visible) { %>
                    <a href="<%= item.href %>" class="menu-item <%= activePage === item.key ? 'active' : '' %>">
                        <span class="menu-item-icon"><%= item.icon %></span>
                        <span class="menu-item-content">
                            <span class="menu-item-title"><%= item.label %></span>
                            <span class="menu-item-caption"><%= item.caption %></span>
                        </span>
                    </a>
                <% } %>
            <% }) %>
        </nav>

        <div class="sidebar-footer">
            <div class="sidebar-status">Frontend administrativo em Node + EJS</div>

            <div class="user-info">
                <div class="user-avatar"><%= userInitial %></div>
                <div class="user-details">
                    <div class="user-name"><%= username %></div>
                    <div class="user-role"><%= sidebarRole %></div>
                </div>
            </div>

            <a href="/logout" class="btn-logout">
                <span>🚪 Encerrar sessão</span>
            </a>
        </div>
    </div>
</aside>

<div class="sidebar-overlay" onclick="document.body.classList.remove('sidebar-open')"></div>