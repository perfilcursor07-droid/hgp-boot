<%
    const isSidebarAdmin = typeof isAdmin === 'boolean' ? isAdmin : true;
    const sidebarRole = typeof role !== 'undefined' ? role : 'Administrador';
    const userInitial = typeof username === 'string' && username.length ? username.charAt(0).toUpperCase() : 'U';
    const menuItems = [
        { key: 'dashboard', href: '/dashboard', label: 'Dashboard', icon: '📊', visible: isSidebarAdmin },
        { key: 'chamados', href: '/chamados', label: 'Chamados', icon: '🧾', visible: true },
        { key: 'messages', href: '/messages', label: 'Mensagens', icon: '💬', visible: isSidebarAdmin },
        { key: 'contacts', href: '/contacts', label: 'Contatos', icon: '👥', visible: isSidebarAdmin },
        { key: 'usuarios', href: '/usuarios', label: 'Usuários', icon: '👤', visible: isSidebarAdmin },
        { key: 'escala', href: '/escala', label: 'Escala', icon: '📅', visible: isSidebarAdmin },
        { key: 'fluxo', href: '/fluxo', label: 'Fluxo', icon: '🧭', visible: isSidebarAdmin },
        { key: 'settings', href: '/settings', label: 'Configurações', icon: '⚙️', visible: isSidebarAdmin }
    ];
%>

<aside class="sidebar">
    <div class="sidebar-shell">
        <div class="sidebar-header">
            <div class="sidebar-brand">
                <div class="sidebar-brand-mark">WA</div>
                <div class="sidebar-brand-copy">
                    <span class="sidebar-kicker">Node Control</span>
                    <h1>WhatsApp HGP</h1>
                </div>
            </div>
        </div>

        <nav class="sidebar-menu">
            <% menuItems.forEach((item) => { %>
                <% if (item.visible) { %>
                    <a href="<%= item.href %>" class="menu-item <%= activePage === item.key ? 'active' : '' %>">
                        <span class="menu-item-icon"><%= item.icon %></span>
                        <span class="menu-item-content">
                            <span class="menu-item-title"><%= item.label %></span>
                        </span>
                        <% if (item.key === 'chamados') { %>
                            <span class="menu-live-badge" id="pendingChamadosBadge" style="display: <%= pendingChamadosCount > 0 ? 'inline-flex' : 'none' %>;"><%= pendingChamadosCount > 99 ? '99+' : pendingChamadosCount %></span>
                        <% } %>
                    </a>
                <% } %>
            <% }) %>
        </nav>

        <div class="sidebar-footer">
            <div class="user-info">
                <div class="user-avatar"><%= userInitial %></div>
                <div class="user-details">
                    <div class="user-name"><%= username %></div>
                    <div class="user-role"><%= sidebarRole %></div>
                </div>
            </div>

            <a href="/logout" class="btn-logout">
                <span>🚪 Encerrar sessão</span>
            </a>
        </div>
    </div>
</aside>

<button class="sidebar-toggle-btn" id="sidebarToggleBtn" onclick="toggleDesktopSidebar()" title="Recolher/expandir menu" aria-label="Recolher ou expandir menu lateral">
    <svg class="toggle-chevron" width="10" height="16" viewBox="0 0 10 16" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M8 2L2 8L8 14" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
</button>

<div class="sidebar-overlay" onclick="document.body.classList.remove('sidebar-open')"></div>

<script>
    (function () {
        function toggleDesktopSidebar() {
            document.body.classList.toggle('sidebar-collapsed');
            const collapsed = document.body.classList.contains('sidebar-collapsed');
            localStorage.setItem('sidebar-collapsed', collapsed ? '1' : '0');
        }

        function aplicarPreferenciaSidebar() {
            if (localStorage.getItem('sidebar-collapsed') === '1') {
                document.body.classList.add('sidebar-collapsed');
            }
        }

        window.toggleDesktopSidebar = toggleDesktopSidebar;

        if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', aplicarPreferenciaSidebar, { once: true });
        } else {
            aplicarPreferenciaSidebar();
        }

        async function iniciarBadgeChamados() {
            const pendingBadge = document.getElementById('pendingChamadosBadge');
            if (!pendingBadge) {
                return;
            }

            async function atualizarBadgeChamados() {
                try {
                    const response = await fetch(`/api/chamados/pending-count?t=${Date.now()}`, { cache: 'no-store' });
                    if (!response.ok) {
                        return;
                    }

                    const result = await response.json();
                    if (!result.success) {
                        return;
                    }

                    const totalPendentes = Number(result.total || 0);
                    if (totalPendentes > 0) {
                        pendingBadge.textContent = totalPendentes > 99 ? '99+' : String(totalPendentes);
                        pendingBadge.style.display = 'inline-flex';
                    } else {
                        pendingBadge.style.display = 'none';
                    }
                } catch (error) {
                    console.error('Erro ao atualizar badge de chamados:', error);
                }
            }

            await atualizarBadgeChamados();
            setInterval(atualizarBadgeChamados, 5000);
        }

        if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', iniciarBadgeChamados, { once: true });
        } else {
            iniciarBadgeChamados();
        }
    })();
</script>