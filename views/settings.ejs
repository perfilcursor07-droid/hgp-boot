<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Configurações - WhatsApp HGP</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <div class="dashboard">
        <%- include('partials/sidebar', { activePage: 'settings', username, role: 'Administrador', isAdmin: true }) %>

        <main class="main-content">
            <div class="topbar">
                <div class="topbar-title-group">
                    <button type="button" class="menu-toggle" aria-label="Abrir menu">
                        <span></span>
                        <span></span>
                        <span></span>
                    </button>
                    <h2>Configurações</h2>
                </div>
                <div class="topbar-actions">
                    <span class="badge info">Edição direta do projeto</span>
                </div>
            </div>

            <div class="content">
                <section class="dashboard-hero settings-hero">
                    <div>
                        <p class="eyebrow">Editor interno</p>
                        <h1>Configurações do chatbot</h1>
                        <p class="hero-text">Edite a lógica do atendimento sem abrir IDE. A escala de plantão agora é cadastrada no módulo Escala, direto no sistema.</p>
                    </div>
                    <div class="hero-highlight">
                        <span class="hero-highlight-label">Módulos</span>
                        <strong>chatbot.js</strong>
                        <small>Escala separada em menu próprio</small>
                    </div>
                </section>

                <div class="settings-grid">
                    <div class="card settings-card">
                        <div class="settings-toolbar">
                            <div>
                                <h2>Notificações</h2>
                                <p class="settings-helper">Controle os disparos automáticos do sistema via WhatsApp.</p>
                            </div>
                        </div>

                        <div class="settings-toggle-list">
                            <div class="settings-toggle-item">
                                <div class="settings-toggle-info">
                                    <strong>Notificar usuários sobre novos chamados</strong>
                                    <p>Quando um novo chamado é aberto pelo WhatsApp, envia uma mensagem para todos os usuários ativos com telefone cadastrado.</p>
                                </div>
                                <label class="toggle-switch">
                                    <input type="checkbox" id="toggleNotificarChamados"
                                        <%= (systemSettings.notificar_usuarios_novo_chamado === 'true') ? 'checked' : '' %>
                                        onchange="salvarToggle('notificar_usuarios_novo_chamado', this.checked)">
                                    <span class="toggle-slider"></span>
                                </label>
                            </div>
                        </div>
                    </div>

                    <div class="card settings-card">
                        <div class="settings-toolbar">
                            <div>
                                <h2>Editor do Bot</h2>
                                <p class="settings-helper">Use este card para ajustar a lógica do atendimento. Se houver erro de sintaxe, o arquivo não será salvo.</p>
                            </div>
                            <div class="settings-actions">
                                <button type="button" id="reloadChatbotBtn" class="btn-secondary">Recarregar arquivo</button>
                                <button type="button" id="saveChatbotBtn" class="btn-primary settings-save-btn">Salvar no projeto</button>
                            </div>
                        </div>

                        <div id="chatbotStatusMessage" class="settings-status" style="display: none;"></div>

                        <label class="settings-label" for="chatbotCode">Conteúdo de <%= chatbotFileName %></label>
                        <textarea id="chatbotCode" class="code-editor" spellcheck="false"><%= chatbotCode %></textarea>
                    </div>

                    <div class="card settings-card">
                        <div class="settings-toolbar">
                            <div>
                                <h2>Módulo de Escala</h2>
                                <p class="settings-helper">O plantão agora usa usuários e datas cadastrados no sistema. Gerencie os técnicos em Escala.</p>
                            </div>
                            <div class="settings-actions">
                                <a href="/escala" class="btn-primary settings-save-btn" style="text-decoration: none; display: inline-flex; align-items: center; justify-content: center;">Abrir módulo</a>
                            </div>
                        </div>

                        <div class="settings-status info" style="display: block;">
                            A origem do técnico de plantão deixou de depender de escala.json e passou a vir do banco de dados.
                        </div>
                    </div>
                </div>
            </div>
        </main>
    </div>

    <script>
        const menuToggle = document.querySelector('.menu-toggle');
        const sidebarOverlay = document.querySelector('.sidebar-overlay');
        const saveChatbotBtn = document.getElementById('saveChatbotBtn');
        const reloadChatbotBtn = document.getElementById('reloadChatbotBtn');
        const chatbotCode = document.getElementById('chatbotCode');
        const chatbotStatusMessage = document.getElementById('chatbotStatusMessage');

        function toggleSidebar(forceOpen) {
            if (typeof forceOpen === 'boolean') {
                document.body.classList.toggle('sidebar-open', forceOpen);
                return;
            }

            document.body.classList.toggle('sidebar-open');
        }

        function showStatus(element, type, message) {
            element.className = `settings-status ${type}`;
            element.textContent = message;
            element.style.display = 'block';
        }

        async function getJsonOrThrow(response) {
            if (response.status === 401) {
                window.location.href = '/';
                throw new Error('Sessão expirada');
            }

            const data = await response.json();
            if (!response.ok) {
                throw new Error(data.details || data.message || 'Erro inesperado');
            }

            return data;
        }

        async function reloadFile(url, button, target, statusElement) {
            button.disabled = true;

            try {
                const response = await fetch(url);
                const data = await getJsonOrThrow(response);
                target.value = data.content || '';
                showStatus(statusElement, 'info', 'Arquivo recarregado do projeto.');
            } catch (error) {
                showStatus(statusElement, 'error', error.message);
            } finally {
                button.disabled = false;
            }
        }

        async function saveFile(url, button, target, statusElement, idleLabel) {
            button.disabled = true;
            button.textContent = 'Salvando...';

            try {
                const response = await fetch(url, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify({ content: target.value })
                });

                const data = await getJsonOrThrow(response);
                showStatus(statusElement, 'success', data.message || 'Arquivo salvo com sucesso.');
            } catch (error) {
                showStatus(statusElement, 'error', error.message);
            } finally {
                button.disabled = false;
                button.textContent = idleLabel;
            }
        }

        if (menuToggle) {
            menuToggle.addEventListener('click', () => toggleSidebar());
        }

        if (sidebarOverlay) {
            sidebarOverlay.addEventListener('click', () => toggleSidebar(false));
        }

        document.querySelectorAll('.menu-item, .btn-logout').forEach((item) => {
            item.addEventListener('click', () => {
                if (window.innerWidth <= 900) {
                    toggleSidebar(false);
                }
            });
        });

        reloadChatbotBtn.addEventListener('click', () => reloadFile('/api/settings/chatbot-file', reloadChatbotBtn, chatbotCode, chatbotStatusMessage));
        saveChatbotBtn.addEventListener('click', () => saveFile('/api/settings/chatbot-file', saveChatbotBtn, chatbotCode, chatbotStatusMessage, 'Salvar no projeto'));

        async function salvarToggle(key, value) {
            try {
                const response = await fetch('/api/settings/system', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ key, value: value ? 'true' : 'false' })
                });
                const data = await response.json();
                if (!data.success) throw new Error(data.message);
            } catch (error) {
                alert('Erro ao salvar: ' + error.message);
            }
        }
    </script>
</body>
</html>