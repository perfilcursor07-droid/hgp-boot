<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Contatos - WhatsApp HGP</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <div class="dashboard">
        <%- include('partials/sidebar', { activePage: 'contacts', username, role: 'Administrador', isAdmin: true }) %>

        <!-- Main Content -->
        <main class="main-content">
            <div class="topbar">
                <div class="topbar-title-group">
                    <button class="menu-toggle" onclick="document.body.classList.toggle('sidebar-open')">
                        <span></span>
                        <span></span>
                        <span></span>
                    </button>
                    <h2>👥 Contatos</h2>
                </div>
                <div class="topbar-actions">
                    <button onclick="syncContacts()" class="btn btn-primary">🔄 Sincronizar Contatos</button>
                </div>
            </div>

            <div class="content">
                <!-- Stats -->
                <div class="stats-grid">
                    <div class="stat-card">
                        <div class="stat-icon blue">👥</div>
                        <div class="stat-info">
                            <h3><%= stats.total %></h3>
                            <p>Total de Contatos</p>
                        </div>
                    </div>
                    <div class="stat-card">
                        <div class="stat-icon green">✨</div>
                        <div class="stat-info">
                            <h3><%= stats.today %></h3>
                            <p>Novos Hoje</p>
                        </div>
                    </div>
                    <div class="stat-card">
                        <div class="stat-icon orange">📊</div>
                        <div class="stat-info">
                            <h3><%= stats.week %></h3>
                            <p>Ativos (7 dias)</p>
                        </div>
                    </div>
                </div>

                <!-- Tabela de Contatos -->
                <div class="card">
                    <h2>Lista de Contatos</h2>
                    <div style="margin: 16px 0;">
                        <input type="text" id="searchInput" placeholder="🔍 Buscar por nome ou telefone..." class="search-input">
                    </div>
                    <div class="messages-container">
                        <table class="messages-table">
                            <thead>
                                <tr>
                                    <th>Telefone</th>
                                    <th>Nome</th>
                                    <th>Primeira Mensagem</th>
                                    <th>Última Mensagem</th>
                                    <th>Total de Mensagens</th>
                                </tr>
                            </thead>
                            <tbody id="contactsTable">
                                <% if (contacts.length === 0) { %>
                                    <tr>
                                        <td colspan="5" class="no-messages">
                                            Nenhum contato encontrado. Clique em "Sincronizar Contatos" para atualizar.
                                        </td>
                                    </tr>
                                <% } else { %>
                                    <% contacts.forEach(contact => { %>
                                        <tr>
                                            <td><%= contact.phone_number %></td>
                                            <td><strong><%= contact.contact_name || 'Sem nome' %></strong></td>
                                            <td><%= contact.first_message_at ? new Date(contact.first_message_at).toLocaleString('pt-BR') : '-' %></td>
                                            <td><%= contact.last_message_at ? new Date(contact.last_message_at).toLocaleString('pt-BR') : '-' %></td>
                                            <td><span class="badge info"><%= contact.message_count %></span></td>
                                        </tr>
                                    <% }) %>
                                <% } %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </main>
    </div>

    <script>
        // Busca em tempo real
        document.getElementById('searchInput').addEventListener('input', function(e) {
            const searchTerm = e.target.value.toLowerCase();
            const rows = document.querySelectorAll('#contactsTable tr');
            
            rows.forEach(row => {
                const text = row.textContent.toLowerCase();
                row.style.display = text.includes(searchTerm) ? '' : 'none';
            });
        });

        // Sincronizar contatos
        async function syncContacts() {
            const btn = event.target;
            btn.disabled = true;
            btn.textContent = '⏳ Sincronizando...';
            
            try {
                const response = await fetch('/api/contacts/sync', {
                    method: 'POST'
                });
                
                const data = await response.json();
                
                if (data.success) {
                    alert(`✓ ${data.message}\n\nContatos sincronizados: ${data.synced}`);
                    location.reload();
                } else {
                    alert('✗ ' + data.message);
                }
            } catch (error) {
                alert('✗ Erro ao sincronizar contatos');
                console.error(error);
            } finally {
                btn.disabled = false;
                btn.textContent = '🔄 Sincronizar Contatos';
            }
        }
    </script>
</body>
</html>
