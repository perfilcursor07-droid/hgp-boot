<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Chamados - WhatsApp HGP</title>
    <link rel="stylesheet" href="/css/style.css">
    <style>
        .chat-badge {
            position: absolute;
            top: -5px;
            right: -5px;
            background: #ef4444;
            color: white;
            border-radius: 50%;
            width: 18px;
            height: 18px;
            font-size: 11px;
            font-weight: bold;
            display: flex;
            align-items: center;
            justify-content: center;
            border: 2px solid white;
        }
    </style>
</head>
<body>
    <% const isAdmin = typeof nivelAcesso !== 'undefined' && nivelAcesso === 'administrador'; %>
    <div class="dashboard">
        <%- include('partials/sidebar', { activePage: 'chamados', username, role: isAdmin ? 'Administrador' : 'Gestor', isAdmin }) %>

        <main class="main-content">
            <div class="topbar">
                <div class="topbar-title-group">
                    <button class="menu-toggle" onclick="document.body.classList.toggle('sidebar-open')">
                        <span></span>
                        <span></span>
                        <span></span>
                    </button>
                    <h2 style="display: flex; align-items: center; gap: 10px;">
                        <span>🧾 Chamados</span>
                        <span id="topbarPendingBadge" class="menu-live-badge" style="display: <%= (contagem.pendente || 0) > 0 ? 'inline-flex' : 'none' %>;">
                            <%= contagem.pendente || 0 %>
                        </span>
                    </h2>
                </div>
                <div class="topbar-actions">
                    <button type="button" class="btn btn-secondary" onclick="toggleDesktopSidebar()">🗂️ Recolher lateral</button>
                    <button onclick="carregarMeusAtendimentos()" class="btn btn-secondary">📋 Meus Atendimentos</button>
                </div>
            </div>

            <div class="content">
                <div class="stats-grid">
                    <div class="stat-card">
                        <div class="stat-icon green">🟢</div>
                        <div class="stat-info">
                            <h3 id="statsAberto"><%= contagem.aberto || 0 %></h3>
                            <p>Abertos</p>
                        </div>
                    </div>
                    <div class="stat-card">
                        <div class="stat-icon orange">🕗</div>
                        <div class="stat-info">
                            <h3 id="statsPendente"><%= contagem.pendente || 0 %></h3>
                            <p>Pendentes</p>
                        </div>
                    </div>
                    <div class="stat-card">
                        <div class="stat-icon blue">⏳</div>
                        <div class="stat-info">
                            <h3 id="statsAtendimento"><%= contagem.em_atendimento || 0 %></h3>
                            <p>Em Atendimento</p>
                        </div>
                    </div>
                    <div class="stat-card">
                        <div class="stat-icon purple">✅</div>
                        <div class="stat-info">
                            <h3 id="statsFinalizado"><%= contagem.finalizado || 0 %></h3>
                            <p>Finalizados</p>
                        </div>
                    </div>
                </div>

                <div class="card">
                    <h2>Todos os Chamados</h2>
                    <div class="messages-container">
                        <p id="chamadosEmptyState" class="no-messages" style="display: <%= chamados.length === 0 ? 'block' : 'none' %>;">📭 Nenhum chamado registrado ainda</p>
                        <table id="chamadosTable" class="messages-table" style="display: <%= chamados.length === 0 ? 'none' : 'table' %>;">
                            <thead>
                                <tr>
                                    <th>Protocolo</th>
                                    <th>Solicitante</th>
                                    <th>Setor</th>
                                    <th>Categoria</th>
                                    <th>Status</th>
                                    <th>Atendente</th>
                                    <th>Data / Hora</th>
                                    <th>Ações</th>
                                </tr>
                            </thead>
                            <tbody id="chamadosTableBody">
                                <% chamados.forEach((chamado) => { %>
                                    <tr>
                                        <td><strong><%= chamado.protocolo %></strong></td>
                                        <td>
                                            <%= chamado.solicitante_nome %>
                                            <% if (chamado.nome_whatsapp || chamado.telefone_whatsapp) { %>
                                                <button onclick="mostrarDadosWhatsApp('<%= chamado.protocolo %>', '<%= chamado.solicitante_nome %>', '<%= chamado.telefone_contato %>', '<%= chamado.nome_whatsapp || '' %>', '<%= chamado.telefone_whatsapp || '' %>')" class="btn-icon" title="Ver dados do WhatsApp" style="font-size: 14px; margin-left: 5px;">📱</button>
                                            <% } %>
                                        </td>
                                        <td><%= chamado.setor %></td>
                                        <td><%= chamado.categoria %></td>
                                        <td>
                                            <% if (chamado.status === 'pendente') { %>
                                                <span class="badge warning">⏳ Pendente</span>
                                            <% } else if (chamado.status === 'aberto') { %>
                                                <span class="badge info">🟢 Aberto</span>
                                            <% } else if (chamado.status === 'em_atendimento') { %>
                                                <span class="badge badge-atendimento">⏳ Em Atendimento</span>
                                            <% } else if (chamado.status === 'finalizado') { %>
                                                <span class="badge success">✅ Finalizado</span>
                                            <% } %>
                                        </td>
                                        <td><%= chamado.atendente_nome || '-' %></td>
                                        <td>
                                            <strong><%= new Date(chamado.criado_em).toLocaleDateString('pt-BR') %></strong><br>
                                            <small><%= new Date(chamado.criado_em).toLocaleTimeString('pt-BR', { hour: '2-digit', minute: '2-digit' }) %></small>
                                        </td>
                                        <td>
                                            <div class="action-buttons">
                                            <% if (chamado.status !== 'finalizado') { %>
                                                    <% if (chamado.status !== 'em_atendimento') { %>
                                                        <button onclick="atenderChamado(<%= chamado.id %>, '<%= chamado.protocolo %>')" class="btn-action-mini" title="Atender">
                                                            ✋ Atender
                                                        </button>
                                                    <% } %>
                                                    <button onclick="abrirChat(<%= chamado.id %>, '<%= chamado.protocolo %>')" class="btn-action-mini" title="Chat" style="position: relative;">
                                                        💬 Chat
                                                        <span id="badge-<%= chamado.id %>" class="chat-badge" style="display: none;"></span>
                                                    </button>
                                                <button onclick="verDetalhes('<%= chamado.protocolo %>', '<%= chamado.categoria %>', '<%= chamado.solicitante_nome %>', '<%= chamado.setor %>', '<%= chamado.ip_maquina || '' %>', '<%= chamado.telefone_contato || '' %>', `<%= (chamado.descricao || '').replace(/`/g, '\`').replace(/\n/g, '\n') %>` )" class="btn-action-mini" title="Ver Detalhes">Detalhes</button>
                                                    <% if (isAdmin) { %>
                                                        <button onclick="abrirModalEncaminhar(<%= chamado.id %>, '<%= chamado.protocolo %>')" class="btn-action-mini" title="<%= chamado.status === 'em_atendimento' ? 'Reencaminhar' : 'Encaminhar' %>"><%= chamado.status === 'em_atendimento' ? '🔄 Reenc.' : '📤 Encam.' %></button>
                                                <% } %>
                                                    <button onclick="abrirModalEncerrar(<%= chamado.id %>, '<%= chamado.protocolo %>')" class="btn-action-mini btn-action-danger" title="Encerrar">✅ Encerrar</button>
                                            <% } else { %>
                                                    <button onclick="abrirChat(<%= chamado.id %>, '<%= chamado.protocolo %>')" class="btn-action-mini" title="Ver Chat">💬 Chat</button>
                                                    <button onclick="verDetalhes('<%= chamado.protocolo %>', '<%= chamado.categoria %>', '<%= chamado.solicitante_nome %>', '<%= chamado.setor %>', '<%= chamado.ip_maquina || '' %>', '<%= chamado.telefone_contato || '' %>', `<%= (chamado.descricao || '').replace(/`/g, '\`').replace(/\n/g, '\n') %>` )" class="btn-action-mini" title="Ver Detalhes">📋 Detalhes</button>
                                            <% } %>
                                            </div>
                                        </td>
                                    </tr>
                                <% }) %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </main>
    </div>

    <!-- Modal Encaminhar Chamado -->
    <div id="modalEncaminhar" class="modal">
        <div class="modal-content">
            <div class="modal-header">
                <h2>📤 Encaminhar Chamado</h2>
                <span class="modal-close" onclick="fecharModalEncaminhar()">&times;</span>
            </div>
            <form id="formEncaminhar" onsubmit="encaminharChamado(event)">
                <input type="hidden" id="encaminharChamadoId" name="chamadoId">
                <p>Protocolo: <strong id="encaminharProtocolo"></strong></p>
                
                <div class="form-group">
                    <label for="gestorId">Selecione o Gestor *</label>
                    <select id="gestorId" name="gestorId" required style="width: 100%; padding: 12px; border: 2px solid #e2e8f0; border-radius: 8px;">
                        <option value="">Carregando gestores...</option>
                    </select>
                </div>

                <div class="modal-actions">
                    <button type="button" onclick="fecharModalEncaminhar()" class="btn btn-secondary">Cancelar</button>
                    <button type="submit" class="btn btn-primary">Encaminhar</button>
                </div>
            </form>
        </div>
    </div>

    <!-- Modal Encerrar Chamado -->
    <div id="modalEncerrar" class="modal">
        <div class="modal-content">
            <div class="modal-header">
                <h2>Encerrar Chamado</h2>
                <span class="modal-close" onclick="fecharModalEncerrar()">&times;</span>
            </div>
            <form id="formEncerrar" onsubmit="encerrarChamado(event)">
                <input type="hidden" id="chamadoId" name="chamadoId">
                <p>Protocolo: <strong id="chamadoProtocolo"></strong></p>
                
                <div class="form-group">
                    <label for="observacoes">Observações (opcional)</label>
                    <textarea id="observacoes" name="observacoes" rows="4" style="width: 100%; padding: 12px; border: 2px solid #e2e8f0; border-radius: 8px;"></textarea>
                </div>

                <div class="modal-actions">
                    <button type="button" onclick="fecharModalEncerrar()" class="btn btn-secondary">Cancelar</button>
                    <button type="submit" class="btn btn-primary">Encerrar Chamado</button>
                </div>
            </form>
        </div>
    </div>

    <!-- Modal Meus Atendimentos -->
    <div id="modalMeusAtendimentos" class="modal">
        <div class="modal-content" style="max-width: 900px;">
            <div class="modal-header">
                <h2>📋 Meus Atendimentos</h2>
                <span class="modal-close" onclick="fecharModalMeusAtendimentos()">&times;</span>
            </div>
            <div style="padding: 24px;">
                <div id="meusAtendimentosContent">
                    <p style="text-align: center; color: #64748b;">Carregando...</p>
                </div>
            </div>
        </div>
    </div>

    <script>
        const isAdmin = <%= isAdmin ? 'true' : 'false' %>;
        const initialChamados = <%- JSON.stringify(chamados || []) %>;
        let gestoresCache = [];
        let chamadosAutoRefresh = null;
        let chamadosState = initialChamados;

        function escapeHtml(value) {
            return String(value || '')
                .replace(/&/g, '&amp;')
                .replace(/</g, '&lt;')
                .replace(/>/g, '&gt;')
                .replace(/"/g, '&quot;')
                .replace(/'/g, '&#39;');
        }

        function formatarDataHora(data) {
            const parsed = new Date(data);
            return {
                data: parsed.toLocaleDateString('pt-BR'),
                hora: parsed.toLocaleTimeString('pt-BR', { hour: '2-digit', minute: '2-digit' })
            };
        }

        function montarBadgeStatus(status) {
            if (status === 'pendente') return '<span class="badge warning">⏳ Pendente</span>';
            if (status === 'aberto') return '<span class="badge info">🟢 Aberto</span>';
            if (status === 'em_atendimento') return '<span class="badge badge-atendimento">⏳ Em Atendimento</span>';
            return '<span class="badge success">✅ Finalizado</span>';
        }

        function montarAcoesChamado(chamado) {
            const protocolo = escapeHtml(chamado.protocolo);
            const categoria = escapeHtml(chamado.categoria);
            const solicitante = escapeHtml(chamado.solicitante_nome);
            const setor = escapeHtml(chamado.setor);
            const ip = escapeHtml(chamado.ip_maquina || '');
            const telefone = escapeHtml(chamado.telefone_contato || '');
            const descricao = escapeHtml(chamado.descricao || '');

            let html = '<div class="action-buttons">';

            if (chamado.status !== 'finalizado') {
                if (chamado.status !== 'em_atendimento') {
                    html += `<button onclick="atenderChamado(${chamado.id}, '${protocolo}')" class="btn-action-mini" title="Atender">✋ Atender</button>`;
                }

                html += `<button onclick="abrirChat(${chamado.id}, '${protocolo}')" class="btn-action-mini" title="Chat" style="position: relative;">💬 Chat<span id="badge-${chamado.id}" class="chat-badge" style="display: none;"></span></button>`;
                html += `<button onclick="verDetalhes('${protocolo}', '${categoria}', '${solicitante}', '${setor}', '${ip}', '${telefone}', '${descricao}')" class="btn-action-mini" title="Ver Detalhes">📋 Detalhes</button>`;

                if (isAdmin) {
                    html += chamado.status === 'em_atendimento'
                        ? `<button onclick="abrirModalEncaminhar(${chamado.id}, '${protocolo}')" class="btn-action-mini" title="Reencaminhar">🔄 Reenc.</button>`
                        : `<button onclick="abrirModalEncaminhar(${chamado.id}, '${protocolo}')" class="btn-action-mini" title="Encaminhar">📤 Encam.</button>`;
                }

                html += `<button onclick="abrirModalEncerrar(${chamado.id}, '${protocolo}')" class="btn-action-mini btn-action-danger" title="Encerrar">✅ Encerrar</button>`;
            } else {
                html += `<button onclick="abrirChat(${chamado.id}, '${protocolo}')" class="btn-action-mini" title="Ver Chat">💬 Chat</button>`;
                html += `<button onclick="verDetalhes('${protocolo}', '${categoria}', '${solicitante}', '${setor}', '${ip}', '${telefone}', '${descricao}')" class="btn-action-mini" title="Ver Detalhes">📋 Detalhes</button>`;
            }

            html += '</div>';
            return html;
        }

        function renderChamadosTable(chamados) {
            const tabelaChamados = document.getElementById('chamadosTable');
            const tbody = document.getElementById('chamadosTableBody');
            const emptyState = document.getElementById('chamadosEmptyState');
            if (!tabelaChamados || !tbody || !emptyState) {
                return;
            }

            if (!Array.isArray(chamados) || chamados.length === 0) {
                tbody.innerHTML = '';
                emptyState.style.display = 'block';
                tabelaChamados.style.display = 'none';
                return;
            }

            emptyState.style.display = 'none';
            tabelaChamados.style.display = 'table';
            tbody.innerHTML = chamados.map((chamado) => {
                const dataHora = formatarDataHora(chamado.criado_em);
                const dadosWhatsApp = (chamado.nome_whatsapp || chamado.telefone_whatsapp)
                    ? `<button onclick="mostrarDadosWhatsApp('${escapeHtml(chamado.protocolo)}', '${escapeHtml(chamado.solicitante_nome)}', '${escapeHtml(chamado.telefone_contato || '')}', '${escapeHtml(chamado.nome_whatsapp || '')}', '${escapeHtml(chamado.telefone_whatsapp || '')}')" class="btn-icon" title="Ver dados do WhatsApp" style="font-size: 14px; margin-left: 5px;">📱</button>`
                    : '';

                return `
                    <tr>
                        <td><strong>${escapeHtml(chamado.protocolo)}</strong></td>
                        <td>${escapeHtml(chamado.solicitante_nome)}${dadosWhatsApp}</td>
                        <td>${escapeHtml(chamado.setor)}</td>
                        <td>${escapeHtml(chamado.categoria)}</td>
                        <td>${montarBadgeStatus(chamado.status)}</td>
                        <td>${escapeHtml(chamado.atendente_nome || '-')}</td>
                        <td><strong>${dataHora.data}</strong><br><small>${dataHora.hora}</small></td>
                        <td>${montarAcoesChamado(chamado)}</td>
                    </tr>
                `;
            }).join('');
        }

        function renderStats(contagem) {
            document.getElementById('statsAberto').textContent = contagem.aberto || 0;
            document.getElementById('statsPendente').textContent = contagem.pendente || 0;
            document.getElementById('statsAtendimento').textContent = contagem.em_atendimento || 0;
            document.getElementById('statsFinalizado').textContent = contagem.finalizado || 0;

            const topbarPendingBadge = document.getElementById('topbarPendingBadge');
            if (topbarPendingBadge) {
                const totalPendentes = Number(contagem.pendente || 0);
                if (totalPendentes > 0) {
                    topbarPendingBadge.textContent = totalPendentes > 99 ? '99+' : String(totalPendentes);
                    topbarPendingBadge.style.display = 'inline-flex';
                } else {
                    topbarPendingBadge.style.display = 'none';
                }
            }
        }

        async function atualizarOverviewChamados() {
            try {
                const response = await fetch(`/api/chamados/overview?t=${Date.now()}`, { cache: 'no-store' });
                const result = await response.json();

                if (!result.success) {
                    return;
                }

                chamadosState = result.chamados || [];
                renderStats(result.contagem || {});
                renderChamadosTable(chamadosState);
                await verificarMensagensNaoLidas();
            } catch (error) {
                console.error('Erro ao atualizar overview de chamados:', error);
            }
        }

        function toggleDesktopSidebar() {
            document.body.classList.toggle('sidebar-collapsed');
            localStorage.setItem('sidebar-collapsed', document.body.classList.contains('sidebar-collapsed') ? '1' : '0');
        }

        function aplicarPreferenciaSidebar() {
            if (localStorage.getItem('sidebar-collapsed') === '1') {
                document.body.classList.add('sidebar-collapsed');
            }
        }

        function algumModalAberto() {
            return Array.from(document.querySelectorAll('.modal')).some((modal) => modal.style.display === 'flex');
        }

        function iniciarAutoRefreshChamados() {
            if (chamadosAutoRefresh) {
                clearInterval(chamadosAutoRefresh);
            }

            chamadosAutoRefresh = setInterval(async () => {
                if (!document.hidden && !algumModalAberto()) {
                    await atualizarOverviewChamados();
                }
            }, 5000);
        }

        // Carregar gestores ao iniciar a página
        async function carregarGestores() {
            try {
                const response = await fetch('/api/usuarios/gestores');
                
                if (!response.ok) {
                    console.error('Erro ao carregar gestores:', response.status);
                    return;
                }
                
                const result = await response.json();

                if (result.success) {
                    gestoresCache = result.gestores;
                    console.log('Gestores carregados:', gestoresCache.length);
                } else {
                    console.error('Erro na resposta:', result.message);
                }
            } catch (error) {
                console.error('Erro ao carregar gestores:', error);
            }
        }

        // Carregar gestores quando a página carregar
        document.addEventListener('DOMContentLoaded', function() {
            aplicarPreferenciaSidebar();
            carregarGestores();
            renderChamadosTable(chamadosState);
            atualizarOverviewChamados();
            iniciarAutoRefreshChamados();
        });

        async function abrirModalEncaminhar(id, protocolo) {
            document.getElementById('encaminharChamadoId').value = id;
            document.getElementById('encaminharProtocolo').textContent = protocolo;
            
            const select = document.getElementById('gestorId');
            select.innerHTML = '<option value="">Carregando gestores...</option>';
            
            document.getElementById('modalEncaminhar').style.display = 'flex';
            
            // Buscar gestores diretamente
            try {
                const response = await fetch('/api/usuarios/gestores');
                
                console.log('Response status:', response.status);
                console.log('Response ok:', response.ok);
                
                if (!response.ok) {
                    const text = await response.text();
                    console.error('Erro na resposta:', text);
                    select.innerHTML = '<option value="">Erro ao carregar gestores</option>';
                    alert('Erro ao carregar gestores. Verifique se você está logado como administrador.');
                    return;
                }
                
                const result = await response.json();
                console.log('Resultado:', result);
                
                if (result.success && result.gestores && result.gestores.length > 0) {
                    select.innerHTML = '<option value="">Selecione um gestor...</option>';
                    result.gestores.forEach(gestor => {
                        const option = document.createElement('option');
                        option.value = gestor.id;
                        option.textContent = `${gestor.nome_completo} (${gestor.telefone || 'Sem telefone'})`;
                        select.appendChild(option);
                    });
                    gestoresCache = result.gestores;
                } else {
                    select.innerHTML = '<option value="">Nenhum gestor disponível</option>';
                    console.log('Nenhum gestor encontrado');
                }
            } catch (error) {
                console.error('Erro ao buscar gestores:', error);
                select.innerHTML = '<option value="">Erro ao carregar gestores</option>';
                alert('Erro ao carregar gestores: ' + error.message);
            }
        }

        function fecharModalEncaminhar() {
            document.getElementById('modalEncaminhar').style.display = 'none';
        }

        async function encaminharChamado(event) {
            event.preventDefault();

            const chamadoId = document.getElementById('encaminharChamadoId').value;
            const gestorId = document.getElementById('gestorId').value;

            if (!gestorId) {
                alert('Por favor, selecione um gestor');
                return;
            }

            try {
                const response = await fetch(`/api/chamados/${chamadoId}/encaminhar`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ gestorId })
                });

                const result = await response.json();

                if (result.success) {
                    alert('✓ ' + result.message + '\n\nNotificações foram enviadas via WhatsApp para o gestor e o solicitante.');
                    location.reload();
                } else {
                    alert('✗ ' + result.message);
                }
            } catch (error) {
                alert('✗ Erro ao encaminhar chamado');
                console.error(error);
            }
        }

        async function atenderChamado(id, protocolo) {
            if (!confirm(`Deseja iniciar o atendimento do chamado ${protocolo}?`)) return;

            try {
                const response = await fetch(`/api/chamados/${id}/atender`, {
                    method: 'POST'
                });

                const result = await response.json();

                if (result.success) {
                    alert('✓ ' + result.message + '\n\nUma mensagem foi enviada ao solicitante pelo WhatsApp.');
                    location.reload();
                } else {
                    alert('✗ ' + result.message);
                }
            } catch (error) {
                alert('✗ Erro ao iniciar atendimento');
                console.error(error);
            }
        }

        function abrirModalEncerrar(id, protocolo) {
            document.getElementById('chamadoId').value = id;
            document.getElementById('chamadoProtocolo').textContent = protocolo;
            document.getElementById('observacoes').value = '';
            document.getElementById('modalEncerrar').style.display = 'flex';
        }

        function fecharModalEncerrar() {
            document.getElementById('modalEncerrar').style.display = 'none';
        }

        async function encerrarChamado(event) {
            event.preventDefault();

            const chamadoId = document.getElementById('chamadoId').value;
            const observacoes = document.getElementById('observacoes').value;

            try {
                const response = await fetch(`/api/chamados/${chamadoId}/encerrar`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ observacoes })
                });

                const result = await response.json();

                if (result.success) {
                    alert('✓ ' + result.message + '\n\nUma mensagem foi enviada ao solicitante pelo WhatsApp.');
                    location.reload();
                } else {
                    alert('✗ ' + result.message);
                }
            } catch (error) {
                alert('✗ Erro ao encerrar chamado');
                console.error(error);
            }
        }

        async function carregarMeusAtendimentos() {
            document.getElementById('modalMeusAtendimentos').style.display = 'flex';
            document.getElementById('meusAtendimentosContent').innerHTML = '<p style="text-align: center; color: #64748b;">Carregando...</p>';

            try {
                const response = await fetch('/api/chamados/meus-atendimentos');
                const result = await response.json();

                if (result.success) {
                    if (result.chamados.length === 0) {
                        document.getElementById('meusAtendimentosContent').innerHTML = 
                            '<p style="text-align: center; color: #64748b;">Você ainda não atendeu nenhum chamado.</p>';
                    } else {
                        let html = '<table class="messages-table"><thead><tr>' +
                            '<th>Protocolo</th><th>Solicitante</th><th>Status</th><th>Iniciado em</th><th>Encerrado em</th>' +
                            '</tr></thead><tbody>';

                        result.chamados.forEach(chamado => {
                            const statusBadge = chamado.status === 'em_atendimento' 
                                ? '<span class="badge badge-atendimento">⏳ Em Atendimento</span>'
                                : '<span class="badge success">✅ Finalizado</span>';
                            
                            html += `<tr>
                                <td><strong>${chamado.protocolo}</strong></td>
                                <td>${chamado.solicitante_nome}</td>
                                <td>${statusBadge}</td>
                                <td>${chamado.iniciado_em ? new Date(chamado.iniciado_em).toLocaleString('pt-BR') : '-'}</td>
                                <td>${chamado.encerrado_em ? new Date(chamado.encerrado_em).toLocaleString('pt-BR') : '-'}</td>
                            </tr>`;
                        });

                        html += '</tbody></table>';
                        document.getElementById('meusAtendimentosContent').innerHTML = html;
                    }
                } else {
                    document.getElementById('meusAtendimentosContent').innerHTML = 
                        '<p style="text-align: center; color: #dc2626;">Erro ao carregar atendimentos</p>';
                }
            } catch (error) {
                console.error(error);
                document.getElementById('meusAtendimentosContent').innerHTML = 
                    '<p style="text-align: center; color: #dc2626;">Erro ao carregar atendimentos</p>';
            }
        }

        function fecharModalMeusAtendimentos() {
            document.getElementById('modalMeusAtendimentos').style.display = 'none';
        }

        // Fechar modais ao clicar fora
        window.onclick = function(event) {
            if (event.target.classList.contains('modal') && event.target.id !== 'modalChat') {
                event.target.style.display = 'none';
            }
        }
    </script>
</body>
</html>

    <!-- Modal Chat -->
    <div id="modalChat" class="modal" data-lock-backdrop="true">
        <div class="modal-content chat-modal-content">
            <div class="modal-header chat-modal-header">
                <div class="chat-modal-title-wrap">
                    <h2>💬 Chat - <span id="chatProtocolo"></span></h2>
                    <span class="chat-modal-subtitle">Conversa do atendimento em tempo real</span>
                    <div class="chat-modal-contact-meta">
                        <span id="chatSolicitanteNome">Solicitante</span>
                        <span id="chatSolicitanteTelefone">Sem telefone</span>
                    </div>
                </div>
                <span class="modal-close" onclick="fecharChat()">&times;</span>
            </div>
            <div class="chat-modal-body">
                <div id="chatMessages" class="chat-messages">
                    <p class="chat-empty">Carregando mensagens...</p>
                </div>
                <form id="formChat" class="chat-compose" onsubmit="enviarMensagemChat(event)">
                    <input type="hidden" id="chatChamadoId">
                    <textarea 
                        id="chatMensagem" 
                        placeholder="Digite sua mensagem aqui. Você pode escrever várias linhas para orientar o usuário com mais clareza."
                        rows="5"
                        required
                    ></textarea>
                    <div class="chat-compose-actions">
                        <span class="chat-compose-hint">O modal só fecha no botão × para evitar perda de contexto.</span>
                        <button type="submit" class="btn btn-primary">
                            📤 Enviar Mensagem
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- Modal Dados WhatsApp -->
    <div id="modalWhatsApp" class="modal">
        <div class="modal-content" style="max-width: 500px;">
            <div class="modal-header">
                <h2>📱 Dados do WhatsApp</h2>
                <span class="modal-close" onclick="fecharModalWhatsApp()">&times;</span>
            </div>
            <div style="padding: 20px;">
                <p style="margin-bottom: 15px;"><strong>Protocolo:</strong> <span id="whatsProtocolo"></span></p>
                
                <div style="background: #f8fafc; padding: 15px; border-radius: 8px; margin-bottom: 15px;">
                    <h3 style="margin: 0 0 10px 0; color: #3b82f6;">📝 Dados Informados pelo Solicitante</h3>
                    <p style="margin: 5px 0;"><strong>Nome:</strong> <span id="whatsNomeInformado"></span></p>
                    <p style="margin: 5px 0;"><strong>Telefone:</strong> <span id="whatsTelInformado"></span></p>
                </div>
                
                <div style="background: #f0fdf4; padding: 15px; border-radius: 8px;">
                    <h3 style="margin: 0 0 10px 0; color: #10b981;">✅ Dados Reais do WhatsApp</h3>
                    <p style="margin: 5px 0;"><strong>Nome:</strong> <span id="whatsNomeReal"></span></p>
                    <p style="margin: 5px 0;"><strong>Telefone:</strong> <span id="whatsTelReal"></span></p>
                </div>
            </div>
        </div>
    </div>

    <!-- Modal Detalhes do Chamado -->
    <div id="modalDetalhes" class="modal">
        <div class="modal-content" style="max-width: 600px;">
            <div class="modal-header">
                <h2>📋 Detalhes do Chamado</h2>
                <span class="modal-close" onclick="fecharModalDetalhes()">&times;</span>
            </div>
            <div style="padding: 20px;">
                <p style="margin-bottom: 10px;"><strong>📌 Protocolo:</strong> <span id="detProtocolo"></span></p>
                <p style="margin-bottom: 10px;"><strong>📂 Categoria:</strong> <span id="detCategoria"></span></p>
                <p style="margin-bottom: 10px;"><strong>👤 Solicitante:</strong> <span id="detSolicitante"></span></p>
                <p style="margin-bottom: 10px;"><strong>🏢 Setor:</strong> <span id="detSetor"></span></p>
                <p style="margin-bottom: 10px;"><strong>💻 IP:</strong> <span id="detIP"></span></p>
                <p style="margin-bottom: 10px;"><strong>📱 Telefone:</strong> <span id="detTelefone"></span></p>
                <div style="background: #f8fafc; padding: 15px; border-radius: 8px; margin-top: 15px;">
                    <h3 style="margin: 0 0 10px 0;">📝 Descrição do Problema:</h3>
                    <p id="detDescricao" style="white-space: pre-wrap; margin: 0;"></p>
                </div>
            </div>
        </div>
    </div>

    <script>
        let chatInterval = null;

        async function abrirChat(chamadoId, protocolo) {
            const chamadoAtual = chamadosState.find((item) => Number(item.id) === Number(chamadoId));
            document.getElementById('modalChat').style.display = 'flex';
            document.getElementById('chatProtocolo').textContent = protocolo;
            document.getElementById('chatSolicitanteNome').textContent = chamadoAtual?.solicitante_nome || 'Solicitante';
            document.getElementById('chatSolicitanteTelefone').textContent = chamadoAtual?.telefone_contato || chamadoAtual?.telefone_whatsapp || 'Sem telefone';
            document.getElementById('chatChamadoId').value = chamadoId;
            document.getElementById('chatMensagem').value = '';
            
            // Limpar badge de mensagens não lidas
            const badge = document.getElementById(`badge-${chamadoId}`);
            if (badge) {
                badge.style.display = 'none';
            }
            
            await carregarMensagensChat(chamadoId);
            
            // Atualizar mensagens a cada 5 segundos
            chatInterval = setInterval(() => carregarMensagensChat(chamadoId), 5000);
        }

        function fecharChat() {
            document.getElementById('modalChat').style.display = 'none';
            if (chatInterval) {
                clearInterval(chatInterval);
                chatInterval = null;
            }
        }

        async function carregarMensagensChat(chamadoId) {
            try {
                const response = await fetch(`/api/chamados/${chamadoId}/chat`);
                const result = await response.json();

                if (result.success) {
                    const chatMessages = document.getElementById('chatMessages');
                    const scrollAtBottom = chatMessages.scrollHeight - chatMessages.scrollTop === chatMessages.clientHeight;
                    
                    if (result.mensagens.length === 0) {
                        chatMessages.innerHTML = '<p class="chat-empty">Nenhuma mensagem ainda.</p>';
                    } else {
                        let html = '';
                        result.mensagens.forEach(msg => {
                            const isTecnico = msg.remetente_tipo === 'tecnico';
                            const isSistema = msg.remetente_tipo === 'sistema';
                            const data = new Date(msg.enviada_em).toLocaleString('pt-BR');
                            const isImagem = msg.message_type === 'image';
                            const isAudio = msg.message_type === 'audio' || msg.message_type === 'ptt';
                            const isVideo = msg.message_type === 'video';
                            const isArquivo = msg.media_url && !isImagem && !isAudio && !isVideo;
                            
                            const rowClass = isTecnico ? 'from-tech' : (isSistema ? 'from-system' : 'from-user');
                            const bubbleClass = isTecnico ? 'from-tech' : (isSistema ? 'from-system' : 'from-user');
                            const mediaHtml = isImagem
                                ? `<div class="chat-media"><a href="${msg.media_url}" target="_blank" rel="noopener noreferrer"><img src="${msg.media_url}" alt="Imagem enviada"></a></div>`
                                : isAudio
                                    ? `<div class="chat-media"><audio controls><source src="${msg.media_url}" type="${msg.media_mime_type || 'audio/ogg'}"></audio></div>`
                                    : isVideo
                                        ? `<div class="chat-media"><video controls><source src="${msg.media_url}" type="${msg.media_mime_type || 'video/mp4'}"></video></div>`
                                        : isArquivo
                                            ? `<div class="chat-media"><a href="${msg.media_url}" target="_blank" rel="noopener noreferrer">📎 ${msg.media_filename || 'Abrir arquivo'}</a></div>`
                                            : '';
                            
                            html += `
                                <div class="chat-message-row ${rowClass}">
                                    <div class="chat-bubble ${bubbleClass}">
                                        <div class="chat-bubble-author">
                                            ${msg.remetente_nome || 'Sistema'}
                                        </div>
                                        <div class="chat-bubble-text">
                                            ${msg.mensagem}
                                        </div>
                                        ${mediaHtml}
                                        <div class="chat-bubble-time">
                                            ${data}
                                        </div>
                                    </div>
                                </div>
                            `;
                        });
                        chatMessages.innerHTML = html;
                    }
                    
                    // Scroll para o final se já estava no final
                    if (scrollAtBottom || result.mensagens.length > 0) {
                        chatMessages.scrollTop = chatMessages.scrollHeight;
                    }
                }
            } catch (error) {
                console.error('Erro ao carregar mensagens:', error);
            }
        }

        async function enviarMensagemChat(event) {
            event.preventDefault();

            const chamadoId = document.getElementById('chatChamadoId').value;
            const mensagem = document.getElementById('chatMensagem').value.trim();

            if (!mensagem) return;

            try {
                const response = await fetch(`/api/chamados/${chamadoId}/chat/enviar`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ mensagem })
                });

                const result = await response.json();

                if (result.success) {
                    document.getElementById('chatMensagem').value = '';
                    await carregarMensagensChat(chamadoId);
                } else {
                    alert('✗ ' + result.message);
                }
            } catch (error) {
                alert('✗ Erro ao enviar mensagem');
                console.error(error);
            }
        }

        // Verificar mensagens não lidas ao carregar a página
        async function verificarMensagensNaoLidas() {
            const chamados = document.querySelectorAll('[id^="badge-"]');
            
            for (const badge of chamados) {
                const chamadoId = badge.id.replace('badge-', '');
                
                try {
                    const response = await fetch(`/api/chamados/${chamadoId}/chat/nao-lidas`);
                    const result = await response.json();
                    
                    if (result.success && result.total > 0) {
                        badge.textContent = result.total;
                        badge.style.display = 'flex';
                    }
                } catch (error) {
                    console.error(`Erro ao verificar mensagens do chamado ${chamadoId}:`, error);
                }
            }
        }

        // Verificar mensagens não lidas ao carregar e a cada 30 segundos
        verificarMensagensNaoLidas();
        setInterval(verificarMensagensNaoLidas, 30000);

        // Funções para modal de dados WhatsApp
        function mostrarDadosWhatsApp(protocolo, nomeInformado, telInformado, nomeReal, telReal) {
            document.getElementById('modalWhatsApp').style.display = 'flex';
            document.getElementById('whatsProtocolo').textContent = protocolo;
            document.getElementById('whatsNomeInformado').textContent = nomeInformado || 'Não informado';
            document.getElementById('whatsTelInformado').textContent = telInformado || 'Não informado';
            document.getElementById('whatsNomeReal').textContent = nomeReal || 'Não disponível';
            document.getElementById('whatsTelReal').textContent = telReal || 'Não disponível';
        }

        function fecharModalWhatsApp() {
            document.getElementById('modalWhatsApp').style.display = 'none';
        }

        // Funções para modal de detalhes
        function verDetalhes(protocolo, categoria, solicitante, setor, ip, telefone, descricao) {
            document.getElementById('modalDetalhes').style.display = 'flex';
            document.getElementById('detProtocolo').textContent = protocolo;
            document.getElementById('detCategoria').textContent = categoria;
            document.getElementById('detSolicitante').textContent = solicitante;
            document.getElementById('detSetor').textContent = setor;
            document.getElementById('detIP').textContent = ip || 'Não informado';
            document.getElementById('detTelefone').textContent = telefone || 'Não informado';
            document.getElementById('detDescricao').textContent = descricao || 'Sem descrição';
        }

        function fecharModalDetalhes() {
            document.getElementById('modalDetalhes').style.display = 'none';
        }

        // Fechar modais ao clicar fora
        window.addEventListener('click', function(event) {
            const modalWhatsApp = document.getElementById('modalWhatsApp');
            const modalDetalhes = document.getElementById('modalDetalhes');
            
            if (event.target === modalWhatsApp) {
                fecharModalWhatsApp();
            }
            if (event.target === modalDetalhes) {
                fecharModalDetalhes();
            }
        });
    </script>
