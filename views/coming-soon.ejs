<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= page %> - WhatsApp HGP</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <%
        const activeComingSoonPage = page === 'Chamados'
            ? 'chamados'
            : page === 'Mensagens'
                ? 'messages'
                : page === 'Contatos'
                    ? 'contacts'
                    : page === 'Usuários'
                        ? 'usuarios'
                        : page === 'Configurações'
                            ? 'settings'
                            : 'dashboard';
    %>
    <div class="dashboard">
        <%- include('partials/sidebar', { activePage: activeComingSoonPage, username, role: 'Administrador', isAdmin: true }) %>

        <!-- Main Content -->
        <main class="main-content">
            <div class="topbar">
                <div class="topbar-title-group">
                    <button type="button" class="menu-toggle" aria-label="Abrir menu">
                        <span></span>
                        <span></span>
                        <span></span>
                    </button>
                    <h2><%= page %></h2>
                </div>
            </div>

            <div class="content">
                <div class="card" style="text-align: center; padding: 80px 40px;">
                    <h2 style="font-size: 48px; margin-bottom: 20px;">🚧</h2>
                    <h2 style="margin-bottom: 15px;">Em Desenvolvimento</h2>
                    <p style="color: #64748b; font-size: 16px;">Esta funcionalidade estará disponível em breve!</p>
                    <a href="/dashboard" class="btn-primary" style="margin-top: 30px; max-width: 200px; display: inline-block;">
                        ← Voltar ao Dashboard
                    </a>
                </div>
            </div>
        </main>
    </div>

    <script>
        const menuToggle = document.querySelector('.menu-toggle');
        const sidebarOverlay = document.querySelector('.sidebar-overlay');

        function toggleSidebar(forceOpen) {
            if (typeof forceOpen === 'boolean') {
                document.body.classList.toggle('sidebar-open', forceOpen);
                return;
            }

            document.body.classList.toggle('sidebar-open');
        }

        if (menuToggle) {
            menuToggle.addEventListener('click', () => toggleSidebar());
        }

        if (sidebarOverlay) {
            sidebarOverlay.addEventListener('click', () => toggleSidebar(false));
        }

        document.querySelectorAll('.menu-item, .btn-logout').forEach((item) => {
            item.addEventListener('click', () => {
                if (window.innerWidth <= 900) {
                    toggleSidebar(false);
                }
            });
        });
    </script>
</body>
</html>
