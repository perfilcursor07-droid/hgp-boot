<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Mensagens - WhatsApp HGP</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <div class="dashboard">
        <%- include('partials/sidebar', { activePage: 'messages', username, role: 'Administrador', isAdmin: true }) %>

        <!-- Main Content -->
        <main class="main-content">
            <div class="topbar">
                <div class="topbar-title-group">
                    <button type="button" class="menu-toggle" aria-label="Abrir menu">
                        <span></span>
                        <span></span>
                        <span></span>
                    </button>
                    <h2>Mensagens</h2>
                </div>
                <div class="topbar-actions">
                    <span class="badge info"><%= messages.length %> mensagens</span>
                </div>
            </div>

            <div class="content">
                <div class="card">
                    <h2>Registro de Mensagens</h2>
                    
                    <div class="messages-container">
                        <% if (messages.length === 0) { %>
                            <p class="no-messages">📭 Nenhuma mensagem registrada ainda</p>
                        <% } else { %>
                            <table class="messages-table">
                                <thead>
                                    <tr>
                                        <th>Data/Hora</th>
                                        <th>De</th>
                                        <th>Para</th>
                                        <th>Mensagem</th>
                                        <th>Tipo</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% messages.forEach(msg => { %>
                                        <tr class="<%= msg.is_from_me ? 'sent' : 'received' %>">
                                            <td><%= new Date(msg.timestamp).toLocaleString('pt-BR') %></td>
                                            <td><%= msg.from_number %></td>
                                            <td><%= msg.to_number %></td>
                                            <td class="message-body"><%= msg.message_body || '(sem texto)' %></td>
                                            <td>
                                                <span class="badge <%= msg.is_from_me ? 'success' : 'info' %>">
                                                    <%= msg.message_type %>
                                                </span>
                                            </td>
                                        </tr>
                                    <% }); %>
                                </tbody>
                            </table>
                        <% } %>
                    </div>
                </div>
            </div>
        </main>
    </div>

    <script>
        const menuToggle = document.querySelector('.menu-toggle');
        const sidebarOverlay = document.querySelector('.sidebar-overlay');

        function toggleSidebar(forceOpen) {
            if (typeof forceOpen === 'boolean') {
                document.body.classList.toggle('sidebar-open', forceOpen);
                return;
            }

            document.body.classList.toggle('sidebar-open');
        }

        if (menuToggle) {
            menuToggle.addEventListener('click', () => toggleSidebar());
        }

        if (sidebarOverlay) {
            sidebarOverlay.addEventListener('click', () => toggleSidebar(false));
        }

        document.querySelectorAll('.menu-item, .btn-logout').forEach((item) => {
            item.addEventListener('click', () => {
                if (window.innerWidth <= 900) {
                    toggleSidebar(false);
                }
            });
        });
    </script>
</body>
</html>
